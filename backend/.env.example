# Azure OpenAI configuration (required for AI judging)
# Get these from your Azure OpenAI / Foundry resource.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# Authentication — two options:
#  1) Keyless / Entra ID (recommended; required when local auth is disabled by policy):
#     leave AZURE_OPENAI_API_KEY blank. The app uses DefaultAzureCredential
#     (az login locally, or AZURE_CLIENT_ID/AZURE_CLIENT_SECRET/AZURE_TENANT_ID for a
#     service principal in containers). The identity needs the
#     "Cognitive Services OpenAI User" role on the resource.
#  2) API key: set AZURE_OPENAI_API_KEY to a key from the resource.
AZURE_OPENAI_API_KEY=

# App settings
DATABASE_URL=sqlite:///./data/hackathon.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DATA_DIR=./data

# Code collection limits (token/size guardrails for large repos)
MAX_FILES=80
MAX_FILE_CHARS=8000
MAX_TOTAL_CHARS=120000

# Execution-based scoring (Docker sandbox build/test).
# Requires Docker on the host. Adds a deterministic "실행 검증" criterion.
# Degrades gracefully (skipped) when Docker is unavailable.
ENABLE_EXECUTION=true
EXECUTION_WEIGHT=20
EXECUTION_TIMEOUT=240

# Azure deployment bonus — 0-100 scale: detected = min, verified live URL = max.
AZURE_BONUS_MIN=20
AZURE_BONUS_MAX=20

# Microsoft AI stack bonus — graded by number of components used
# (Foundry / Agent Framework / Azure AI Search / Foundry IQ / Foundry Agent Service).
MS_STACK_BONUS_MIN=20
MS_STACK_BONUS_MAX=20
MS_STACK_BONUS_PER=20

# Optional admin token. When set, submit/upload/rejudge/delete/rubric-edit require
# the X-Admin-Token header. Leave blank to keep the app fully open (demo mode).
ADMIN_TOKEN=
